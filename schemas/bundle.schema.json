{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Nerve Bundle",
  "description": "Nerve identity and tools. Prompt and config live in sibling context.json and meta.json files.",
  "type": "object",
  "required": ["name", "version", "description", "role", "tags", "authors", "arqitect_version", "tools"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Nerve identifier (snake_case)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "role": {
      "type": "string",
      "enum": ["tool", "creative", "code"]
    },
    "mode": {
      "type": "string",
      "enum": ["tool_required", "reasoning"],
      "description": "Whether the nerve must call a tool (tool_required) or can answer from LLM knowledge (reasoning). Inferred from tools array if omitted."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["github"],
        "properties": {
          "github": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "minItems": 1
    },
    "arqitect_version": {
      "type": "string",
      "description": "Semver constraint, e.g. >=0.1.0"
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "description": "Tool name — resolved from mcp_tools/{name}/meta.json or mcps/{name}/meta.json" },
          "implementations": {
            "type": "object",
            "description": "Language -> relative path to implementation file",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    }
  }
}
