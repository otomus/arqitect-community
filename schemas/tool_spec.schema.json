{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tool Specification",
  "description": "Language-agnostic tool interface definition",
  "type": "object",
  "required": ["name", "description", "parameters"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "description"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["string", "number", "boolean", "object", "array"] },
          "description": { "type": "string" },
          "required": { "type": "boolean", "default": true },
          "default": {}
        }
      }
    },
    "returns": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "args": { "type": "object" },
          "result": {}
        }
      }
    }
  }
}
