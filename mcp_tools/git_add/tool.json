{
  "name": "git_add",
  "version": "1.0.0",
  "description": "Stage specific files for commit",
  "params": {
    "token": {
      "type": "string",
      "description": "User's Git access token for authentication",
      "required": true
    },
    "files": {
      "type": "string",
      "description": "Comma-separated file paths to stage (wildcard '.' and '-A' are rejected)",
      "required": true
    },
    "path": {
      "type": "string",
      "description": "Path to the Git repository (default: current directory)",
      "required": false
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "git",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "git",
    "version-control",
    "staging"
  ],
  "requires_api_key": true,
  "dependencies": {
    "python": [
      "gitpython"
    ]
  }
}
