{
  "name": "keyboard_press",
  "version": "1.0.0",
  "description": "Press a key or key combination on the keyboard",
  "params": {
    "key": {
      "type": "string",
      "description": "Key to press (e.g. enter, tab, a, f1)",
      "required": true
    },
    "modifiers": {
      "type": "string",
      "description": "Comma-separated modifier keys (e.g. ctrl,shift)",
      "required": false
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "arqitect-community"
  },
  "category": "desktop",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "keyboard",
    "press",
    "hotkey",
    "shortcut",
    "automation",
    "desktop"
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "pyautogui"
    ]
  }
}
