{
  "name": "port_scan",
  "version": "1.0.0",
  "description": "Check which ports are open on a host",
  "params": {
    "host": {
      "type": "string",
      "description": "Host to scan",
      "required": true
    },
    "ports": {
      "type": "string",
      "description": "Comma-separated port numbers or range (e.g. \"80,443\" or \"20-25\")",
      "required": false,
      "default": "22,80,443,8080,8443"
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "arqitect-community"
  },
  "category": "security",
  "implementations": {
    "python": "tool.py",
    "go": "tool.go"
  },
  "tags": [
    "port",
    "scan",
    "network",
    "security",
    "firewall"
  ],
  "requires_api_key": false
}
