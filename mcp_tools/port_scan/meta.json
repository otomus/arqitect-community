{
  "name": "port_scan",
  "version": "1.0.0",
  "description": "Check which ports are open on a host",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "security",
  "tags": [
    "port",
    "scan",
    "network",
    "security",
    "firewall"
  ],
  "parameters": [
    {
      "name": "host",
      "type": "string",
      "description": "Host to scan",
      "required": true
    },
    {
      "name": "ports",
      "type": "string",
      "description": "Comma-separated port numbers or range (e.g. \"80,443\" or \"20-25\")",
      "required": false,
      "default": "22,80,443,8080,8443"
    }
  ],
  "requires_api_key": false
}