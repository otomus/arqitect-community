{
  "name": "file_search",
  "version": "1.0.0",
  "description": "Search for files matching a glob pattern in a directory tree",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "filesystem",
  "tags": [
    "file",
    "search",
    "find",
    "glob",
    "pattern"
  ],
  "parameters": [
    {
      "name": "pattern",
      "type": "string",
      "description": "Glob pattern (e.g. \"**/*.py\")",
      "required": true
    },
    {
      "name": "path",
      "type": "string",
      "description": "Root directory to search from",
      "required": false,
      "default": "."
    }
  ],
  "requires_api_key": false
}