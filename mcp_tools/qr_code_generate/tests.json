[
  {
    "description": "Generate a QR code from a URL",
    "args": {
      "data": "https://example.com",
      "output_path": "/tmp/test_qr.png"
    },
    "expected_keywords": [
      "QR code saved to",
      "/tmp/test_qr.png"
    ]
  },
  {
    "description": "Generate a QR code with custom size",
    "args": {
      "data": "Hello World",
      "output_path": "/tmp/test_qr_large.png",
      "size": 20
    },
    "expected_keywords": [
      "QR code saved to",
      "/tmp/test_qr_large.png"
    ]
  },
  {
    "description": "Empty data should fail",
    "args": {
      "data": "",
      "output_path": "/tmp/test_qr.png"
    },
    "expect_error": true
  }
]
