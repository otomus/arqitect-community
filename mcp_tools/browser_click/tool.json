{
  "name": "browser_click",
  "version": "1.0.0",
  "description": "Click an element on a browser page identified by CSS selector",
  "params": {
    "page_id": {
      "type": "string",
      "description": "UUID of the page returned by browser_open",
      "required": true
    },
    "selector": {
      "type": "string",
      "description": "CSS selector of the element to click",
      "required": true
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "arqitect-community"
  },
  "category": "browser",
  "implementations": {
    "python": "tool.py",
    "typescript": "tool.ts"
  },
  "tags": [
    "browser",
    "automation",
    "playwright",
    "click",
    "interact"
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "playwright"
    ],
    "typescript": [
      "playwright"
    ]
  }
}
