{
  "name": "actuator",
  "version": "1.0.0",
  "description": "Set or get the state of an IoT actuator",
  "params": {
    "actuator_id": {
      "type": "string",
      "description": "Unique identifier of the actuator",
      "required": true
    },
    "value": {
      "type": "string",
      "description": "Value to set the actuator to (required for set)",
      "required": false
    },
    "operation": {
      "type": "string",
      "description": "Operation to perform: set or get",
      "required": true
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "iot",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "iot",
    "actuator",
    "control"
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "requests"
    ]
  }
}
