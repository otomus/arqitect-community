{
  "name": "lock_set",
  "version": "1.0.0",
  "description": "Set the state of a smart lock (lock or unlock)",
  "params": {
    "device_id": {
      "type": "string",
      "description": "Unique identifier of the smart lock",
      "required": true
    },
    "state": {
      "type": "string",
      "description": "Desired lock state: 'lock' or 'unlock'",
      "required": true
    },
    "device_host": {
      "type": "string",
      "description": "IoT gateway host URL",
      "required": true
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "arqitect-community"
  },
  "category": "iot",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "iot",
    "lock",
    "smart-lock",
    "security"
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "requests"
    ]
  }
}
