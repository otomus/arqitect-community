{
  "name": "password_generate",
  "version": "1.0.0",
  "description": "Generate a cryptographically secure random password",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "security",
  "tags": [
    "password",
    "generate",
    "random",
    "secure",
    "credential"
  ],
  "parameters": [
    {
      "name": "length",
      "type": "number",
