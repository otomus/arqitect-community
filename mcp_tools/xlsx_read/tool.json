{
  "name": "xlsx_read",
  "version": "1.0.0",
  "description": "Read data from an Excel XLSX file",
  "params": {
    "file_path": {
      "type": "string",
      "description": "Path to the Excel file to read",
      "required": true
    },
    "sheet": {
      "type": "string",
      "description": "Name of the sheet to read (defaults to the active sheet)",
      "required": false
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "documents",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "xlsx",
    "excel",
    "read",
    "spreadsheet",
    "document"
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "openpyxl"
    ]
  }
}
