{
  "name": "notification_send",
  "version": "1.0.0",
  "description": "Send a push notification",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "communication",
  "tags": [
    "notification",
    "push",
    "alert",
    "notify"
  ],
  "parameters": [
    {
      "name": "title",
      "type": "string",
      "description": "Notification title",
      "required": true
    },
    {
      "name": "body",
      "type": "string",
      "description": "Notification body",
      "required": true
    },
    {
      "name": "target",
      "type": "string",
      "description": "Target platform or device",
      "required": false,
      "default": "local"
    }
  ],
  "requires_api_key": false
}