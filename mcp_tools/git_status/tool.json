{
  "name": "git_status",
  "version": "1.0.0",
  "description": "Get working tree status of a Git repository",
  "params": {
    "token": {
      "type": "string",
      "description": "User's Git access token for authentication",
      "required": true
    },
    "path": {
      "type": "string",
      "description": "Path to the Git repository (default: current directory)",
      "required": false
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "arqitect-community"
  },
  "category": "git",
  "implementations": {
    "python": "tool.py",
    "go": "tool.go"
  },
  "tags": [
    "git",
    "version-control",
    "status"
  ],
  "requires_api_key": true,
  "dependencies": {
    "python": [
      "gitpython"
    ]
  }
}
