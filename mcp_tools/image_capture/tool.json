{
  "name": "image_capture",
  "version": "1.0.0",
  "description": "Capture a screenshot on macOS using screencapture",
  "params": {
    "region": {
      "type": "string",
      "description": "Screen region as 'x,y,w,h' or empty for full screen",
      "required": false,
      "default": ""
    },
    "window": {
      "type": "string",
      "description": "Window name to capture (macOS only)",
      "required": false,
      "default": ""
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 15,
  "author": {
    "github": "sentient-community"
  },
  "category": "media",
  "implementations": {
    "python": "tool.py"
  },
  "tags": ["image", "capture", "screenshot", "screen"],
  "requires_api_key": false
}
