{
  "name": "actuator_get",
  "version": "1.0.0",
  "description": "Get the current state of an IoT actuator",
  "params": {
    "actuator_id": {
      "type": "string",
      "description": "Unique identifier of the actuator",
      "required": true
    },
    "device_host": {
      "type": "string",
      "description": "IoT gateway host URL",
      "required": true
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "iot",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "iot",
    "actuator",
    "state",
    "read"
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "requests"
    ]
  }
}
