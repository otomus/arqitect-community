{
  "name": "dns_lookup",
  "version": "1.0.0",
  "description": "Perform a DNS lookup for a domain name",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "web",
  "tags": [
    "dns",
    "lookup",
    "domain",
    "resolve",
    "network"
  ],
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Domain name to look up",
      "required": true
    },
    {
      "name": "type",
      "type": "string",
      "description": "Record type: A, AAAA, MX, TXT, CNAME, NS",
      "required": false,
      "default": "A"
    }
  ],
  "requires_api_key": false
}