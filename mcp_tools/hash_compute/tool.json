{
  "name": "hash_compute",
  "version": "1.0.0",
  "description": "Compute a cryptographic hash of the input string using the specified algorithm",
  "params": {
    "input": {
      "type": "string",
      "description": "String to hash",
      "required": true
    },
    "algorithm": {
      "type": "string",
      "description": "Hash algorithm: md5, sha1, sha256, sha512",
      "required": false,
      "default": "sha256"
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "data",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "hash",
    "sha256",
    "md5",
    "checksum",
    "crypto"
  ],
  "requires_api_key": false
}
