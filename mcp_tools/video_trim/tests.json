      "input_path": "/nonexistent/video.mp4",
      "output_path": "trimmed.mp4",
      "start": "00:00:10",
      "end": "00:01:00"
    },
    "expected_keywords": [
      "Error",
      "not found"
    ]
  },
  {
    "description": "Trim with invalid start timestamp returns error",
