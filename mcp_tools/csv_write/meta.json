{
  "name": "csv_write",
  "version": "1.0.0",
  "description": "Write data to a CSV file",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "documents",
  "tags": [
    "csv",
    "write",
    "create",
    "data",
    "tabular",
    "document"
  ],
  "parameters": [
    {
      "name": "file_path",
      "type": "string",
      "description": "Output path for the CSV file",
      "required": true
    },
    {
      "name": "data",
      "type": "string",
      "description": "JSON string containing an array of arrays (rows and cells)",
      "required": true
    },
    {
      "name": "delimiter",
      "type": "string",
      "description": "Column delimiter character (defaults to comma)",
      "required": false,
      "default": ","
    }
  ],
  "requires_api_key": false
}
