{
  "name": "csv_write",
  "version": "1.0.0",
  "description": "Write data to a CSV file",
  "params": {
    "file_path": {
      "type": "string",
      "description": "Output path for the CSV file",
      "required": true
    },
    "data": {
      "type": "string",
      "description": "JSON string containing an array of arrays (rows and cells)",
      "required": true
    },
    "delimiter": {
      "type": "string",
      "description": "Column delimiter character (defaults to comma)",
      "required": false,
      "default": ","
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "documents",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "csv",
    "write",
    "create",
    "data",
    "tabular",
    "document"
  ],
  "requires_api_key": false
}
