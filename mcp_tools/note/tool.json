{
  "name": "note",
  "version": "1.0.0",
  "description": "Unified note management: create, read, search, update, and delete notes",
  "params": {
    "operation": {
      "type": "string",
      "description": "Operation to perform: create, read, search, update, delete",
      "required": true
    },
    "id": {
      "type": "string",
      "description": "Note identifier (used for read, update, delete)",
      "required": false
    },
    "title": {
      "type": "string",
      "description": "Note title (used for create, update)",
      "required": false
    },
    "body": {
      "type": "string",
      "description": "Note body content (used for create, update)",
      "required": false
    },
    "query": {
      "type": "string",
      "description": "Search query string (used for search)",
      "required": false
    },
    "folder": {
      "type": "string",
      "description": "Folder name for organizing notes (used for create, search)",
      "required": false
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "productivity",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "notes",
    "create",
    "read",
    "search",
    "update",
    "delete",
    "productivity"
  ],
  "requires_api_key": false
}
