{
  "name": "git_log",
  "version": "1.0.0",
  "description": "Show commit history of a Git repository",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "git",
  "tags": [
    "git",
    "version-control",
    "history"
  ],
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "description": "User's Git access token for authentication",
      "required": true
    },
    {
      "name": "count",
      "type": "integer",
      "description": "Number of commits to show (default: 10)",
      "required": false
    },
    {
      "name": "path",
      "type": "string",
      "description": "Path to the Git repository (default: current directory)",
      "required": false
    }
  ],
  "requires_api_key": true,
  "dependencies": {
    "python": [
      "gitpython"
    ]
  }
}
