{
  "name": "file_grep",
  "version": "1.0.0",
  "description": "Search for a text pattern inside files",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "filesystem",
  "tags": [
    "file",
    "grep",
    "search",
    "content",
    "pattern",
    "text"
  ],
  "parameters": [
    {
      "name": "pattern",
      "type": "string",
      "description": "Text or regex pattern to search for",
      "required": true
    },
    {
      "name": "path",
      "type": "string",
      "description": "File or directory to search in",
      "required": false,
      "default": "."
    },
    {
      "name": "glob",
      "type": "string",
      "description": "File glob filter (e.g. \"*.py\")",
      "required": false,
      "default": "*"
    }
  ],
  "requires_api_key": false
}