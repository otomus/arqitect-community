{
  "name": "git_stash",
  "version": "1.0.0",
  "description": "Stash changes in the working directory",
  "params": {
    "token": {
      "type": "string",
      "description": "User's Git access token for authentication",
      "required": true
    },
    "message": {
      "type": "string",
      "description": "Optional message describing the stash",
      "required": false
    },
    "path": {
      "type": "string",
      "description": "Path to the Git repository (default: current directory)",
      "required": false
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "git",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "git",
    "version-control",
    "stash"
  ],
  "requires_api_key": true,
  "dependencies": {
    "python": [
      "gitpython"
    ]
  }
}
