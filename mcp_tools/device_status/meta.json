{
  "name": "device_status",
  "version": "1.0.0",
  "description": "Get the status of a connected IoT device",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "iot",
  "tags": [
    "iot",
    "device",
    "status",
    "health"
  ],
  "parameters": [
    {
      "name": "device_id",
      "type": "string",
      "description": "Unique identifier of the device",
      "required": true
    },
    {
      "name": "device_host",
      "type": "string",
      "description": "IoT gateway host URL (defaults to SENTIENT_IOT_HOST env var)",
      "required": false
    }
  ],
  "requires_api_key": false
}
