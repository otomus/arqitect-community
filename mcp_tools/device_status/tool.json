{
  "name": "device_status",
  "version": "1.0.0",
  "description": "Get the status of a connected IoT device",
  "params": {
    "device_id": {
      "type": "string",
      "description": "Unique identifier of the device",
      "required": true
    },
    "device_host": {
      "type": "string",
      "description": "IoT gateway host URL",
      "required": true
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "iot",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "iot",
    "device",
    "status",
    "health"
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "requests"
    ]
  }
}
