{
  "name": "hash_verify",
  "version": "1.0.0",
  "description": "Verify that an input matches an expected hash",
  "params": {
    "input": {
      "type": "string",
      "description": "String to verify",
      "required": true
    },
    "hash": {
      "type": "string",
      "description": "Expected hash value",
      "required": true
    },
    "algorithm": {
      "type": "string",
      "description": "Hash algorithm: md5, sha1, sha256, sha512",
      "required": false,
      "default": "sha256"
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "security",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "hash",
    "verify",
    "check",
    "integrity",
    "checksum"
  ],
  "requires_api_key": false
}
