{
  "name": "hash_verify",
  "version": "1.0.0",
  "description": "Verify that an input matches an expected hash",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "security",
  "tags": [
    "hash",
    "verify",
    "check",
    "integrity",
    "checksum"
  ],
  "parameters": [
    {
      "name": "input",
      "type": "string",
      "description": "String to verify",
      "required": true
    },
    {
      "name": "hash",
      "type": "string",
      "description": "Expected hash value",
      "required": true
    },
    {
      "name": "algorithm",
      "type": "string",
      "description": "Hash algorithm: md5, sha1, sha256, sha512",
      "required": false,
      "default": "sha256"
    }
  ],
  "requires_api_key": false
}