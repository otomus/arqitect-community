{
  "name": "sensor_read",
  "version": "1.0.0",
  "description": "Read the current value from an IoT sensor",
  "params": {
    "sensor_id": {
      "type": "string",
      "description": "Unique identifier of the sensor to read",
      "required": true
    },
    "device_host": {
      "type": "string",
      "description": "IoT gateway host URL",
      "required": true
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "iot",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "iot",
    "sensor",
    "read",
    "data"
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "requests"
    ]
  }
}
