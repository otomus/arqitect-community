{
  "name": "git_clone",
  "version": "1.0.0",
  "description": "Clone a remote Git repository",
  "params": {
    "token": {
      "type": "string",
      "description": "User's Git access token for authentication",
      "required": true
    },
    "url": {
      "type": "string",
      "description": "Repository URL to clone",
      "required": true
    },
    "destination": {
      "type": "string",
      "description": "Local directory to clone into (default: derived from URL)",
      "required": false
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "arqitect-community"
  },
  "category": "git",
  "implementations": {
    "python": "tool.py",
    "go": "tool.go"
  },
  "tags": [
    "git",
    "version-control",
    "clone",
    "remote"
  ],
  "requires_api_key": true,
  "dependencies": {
    "python": [
      "gitpython"
    ]
  }
}
