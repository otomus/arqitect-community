{
  "name": "encrypt_text",
  "version": "1.0.0",
  "description": "Encrypt a string using a symmetric key",
  "params": {
    "text": {
      "type": "string",
      "description": "Text to encrypt",
      "required": true
    },
    "key": {
      "type": "string",
      "description": "Encryption key (will be hashed to 32 bytes)",
      "required": true
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "security",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "encrypt",
    "crypto",
    "secret",
    "aes",
    "cipher"
  ],
  "requires_api_key": false
}
