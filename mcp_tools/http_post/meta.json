{
  "name": "http_post",
  "version": "1.0.0",
  "description": "Send an HTTP POST request to a URL",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "web",
  "tags": [
    "http",
    "post",
    "request",
    "api",
    "web"
  ],
  "parameters": [
    {
      "name": "url",
      "type": "string",
      "description": "URL to send the request to",
      "required": true
    },
    {
      "name": "body",
      "type": "string",
      "description": "Request body (JSON string)",
      "required": true
    },
    {
      "name": "headers",
      "type": "string",
      "description": "JSON string of headers",
      "required": false,
      "default": "{}"
    }
  ],
  "requires_api_key": false
}