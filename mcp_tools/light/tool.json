{
  "name": "light",
  "version": "1.0.0",
  "description": "Set or get the state of a smart light",
  "params": {
    "light_id": {
      "type": "string",
      "description": "Unique identifier of the light device",
      "required": true
    },
    "brightness": {
      "type": "string",
      "description": "Brightness level 0-100 (optional, set only)",
      "required": false
    },
    "color": {
      "type": "string",
      "description": "Color value, e.g. hex code or color name (optional, set only)",
      "required": false
    },
    "on": {
      "type": "string",
      "description": "Power state: 'true' or 'false' (optional, set only)",
      "required": false
    },
    "operation": {
      "type": "string",
      "description": "Operation to perform: set or get",
      "required": true
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "arqitect-community"
  },
  "category": "iot",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "iot",
    "light",
    "smart-home",
    "hue"
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "requests"
    ]
  }
}
