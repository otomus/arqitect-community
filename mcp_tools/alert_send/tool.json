{
  "name": "alert_send",
  "version": "1.0.0",
  "description": "Create and record an alert with severity level",
  "params": {
    "title": {
      "type": "string",
      "description": "Alert title",
      "required": true
    },
    "body": {
      "type": "string",
      "description": "Alert body/description",
      "required": true
    },
    "severity": {
      "type": "string",
      "description": "Severity level (info, warning, error, critical)",
      "required": false,
      "default": "info"
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30
}
