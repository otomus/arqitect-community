{
  "name": "docker_run",
  "version": "1.0.0",
  "description": "Run a Docker container from a specified image",
  "params": {
    "image": {
      "type": "string",
      "description": "Docker image to run (e.g. 'nginx:latest')",
      "required": true
    },
    "name": {
      "type": "string",
      "description": "Optional name for the container",
      "required": false
    },
    "ports": {
      "type": "string",
      "description": "Port mapping in host:container format (e.g. '8080:80')",
      "required": false
    },
    "detach": {
      "type": "boolean",
      "description": "Run container in detached mode",
      "required": false,
      "default": true
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "arqitect-community"
  },
  "category": "docker",
  "implementations": {
    "python": "tool.py",
    "go": "tool.go"
  },
  "tags": [
    "docker",
    "container",
    "run",
    "infrastructure"
  ],
  "requires_api_key": false
}
