{
  "name": "git_branch_create",
  "version": "1.0.0",
  "description": "Create a new Git branch",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "git",
  "tags": [
    "git",
    "version-control",
    "branch"
  ],
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "description": "User's Git access token for authentication",
      "required": true
    },
    {
      "name": "name",
      "type": "string",
      "description": "Name of the new branch",
      "required": true
    },
    {
      "name": "path",
      "type": "string",
      "description": "Path to the Git repository (default: current directory)",
      "required": false
    }
  ],
  "requires_api_key": true,
  "dependencies": {
    "python": [
      "gitpython"
    ]
  }
}
