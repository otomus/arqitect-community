{
  "name": "currency_rate",
  "version": "1.0.0",
  "description": "Get the current exchange rate between two currencies",
  "params": {
    "from_currency": {
      "type": "string",
      "description": "Source currency code (e.g. USD, EUR)",
      "required": true
    },
    "to_currency": {
      "type": "string",
      "description": "Target currency code (e.g. GBP, JPY)",
      "required": true
    },
    "api_key": {
      "type": "string",
      "description": "API key for exchangerate-api.com",
      "required": true
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "external",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "currency",
    "exchange",
    "rate",
    "finance"
  ],
  "requires_api_key": true,
  "dependencies": {
    "python": [
      "requests"
    ]
  }
}
