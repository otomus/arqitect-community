{
  "name": "social",
  "version": "1.0.0",
  "description": "Unified social media management: post, read, search, reply, like, followers, and trending",
  "params": {
    "operation": {
      "type": "string",
      "description": "Operation to perform: post, read, search, reply, like, followers, trending",
      "required": true
    },
    "platform": {
      "type": "string",
      "description": "Social media platform (e.g. twitter, mastodon)",
      "required": true
    },
    "post_id": {
      "type": "string",
      "description": "Post identifier (used for read, reply, like)",
      "required": false
    },
    "content": {
      "type": "string",
      "description": "Post or reply content text (used for post, reply)",
      "required": false
    },
    "query": {
      "type": "string",
      "description": "Search query string (used for search)",
      "required": false
    },
    "user": {
      "type": "string",
      "description": "Username (used for followers, read)",
      "required": false
    },
    "media": {
      "type": "string",
      "description": "Media attachment path or URL (used for post)",
      "required": false
    },
    "reaction": {
      "type": "string",
      "description": "Reaction type (used for like; default 'like')",
      "required": false
    },
    "region": {
      "type": "string",
      "description": "Region code for localized trends (used for trending; e.g. US, UK)",
      "required": false
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "arqitect-community"
  },
  "category": "social",
  "implementations": {
    "python": "tool.py",
    "typescript": "tool.ts"
  },
  "tags": [
    "social",
    "post",
    "read",
    "search",
    "reply",
    "like",
    "followers",
    "trending"
  ],
  "requires_api_key": true,
  "dependencies": {
    "python": [
      "requests"
    ]
  }
}
