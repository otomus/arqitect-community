{
  "name": "docker_build",
  "version": "1.0.0",
  "description": "Build a Docker image from a Dockerfile",
  "params": {
    "path": {
      "type": "string",
      "description": "Path to the build context directory containing the Dockerfile",
      "required": true
    },
    "tag": {
      "type": "string",
      "description": "Tag for the built image (e.g. 'myapp:latest')",
      "required": true
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "arqitect-community"
  },
  "category": "docker",
  "implementations": {
    "python": "tool.py",
    "go": "tool.go"
  },
  "tags": [
    "docker",
    "image",
    "build",
    "dockerfile",
    "infrastructure"
  ],
  "requires_api_key": false
}
