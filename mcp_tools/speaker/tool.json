{
  "name": "speaker",
  "version": "1.0.0",
  "description": "Control a smart speaker: play, pause, or adjust volume",
  "params": {
    "device_id": {
      "type": "string",
      "description": "Unique identifier of the speaker device",
      "required": true
    },
    "uri": {
      "type": "string",
      "description": "Media URI to play (optional, play only)",
      "required": false
    },
    "level": {
      "type": "string",
      "description": "Volume level 0-100 (optional, volume only)",
      "required": false
    },
    "operation": {
      "type": "string",
      "description": "Operation to perform: play, pause, or volume",
      "required": true
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "iot",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "iot",
    "speaker",
    "audio",
    "smart-home"
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "requests"
    ]
  }
}
