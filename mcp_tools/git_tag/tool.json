{
  "name": "git_tag",
  "version": "1.0.0",
  "description": "Create a tag in a Git repository",
  "params": {
    "token": {
      "type": "string",
      "description": "User's Git access token for authentication",
      "required": true
    },
    "name": {
      "type": "string",
      "description": "Tag name",
      "required": true
    },
    "message": {
      "type": "string",
      "description": "Tag message (creates an annotated tag if provided)",
      "required": false
    },
    "path": {
      "type": "string",
      "description": "Path to the Git repository (default: current directory)",
      "required": false
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "arqitect-community"
  },
  "category": "git",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "git",
    "version-control",
    "tag"
  ],
  "requires_api_key": true,
  "dependencies": {
    "python": [
      "gitpython"
    ]
  }
}
