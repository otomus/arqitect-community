{
  "name": "git_diff",
  "version": "1.0.0",
  "description": "Show changes in the working tree or staging area",
  "params": {
    "token": {
      "type": "string",
      "description": "User's Git access token for authentication",
      "required": true
    },
    "path": {
      "type": "string",
      "description": "Path to the Git repository (default: current directory)",
      "required": false
    },
    "staged": {
      "type": "boolean",
      "description": "Show only staged changes (default: false)",
      "required": false
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "arqitect-community"
  },
  "category": "git",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "git",
    "version-control",
    "diff"
  ],
  "requires_api_key": true,
  "dependencies": {
    "python": [
      "gitpython"
    ]
  }
}
