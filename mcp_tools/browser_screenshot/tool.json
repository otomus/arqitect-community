{
  "name": "browser_screenshot",
  "version": "1.0.0",
  "description": "Take a screenshot of a browser page and save it to a file",
  "params": {
    "page_id": {
      "type": "string",
      "description": "UUID of the page returned by browser_open",
      "required": true
    },
    "path": {
      "type": "string",
      "description": "Output file path for the screenshot (uses a temp file if omitted)",
      "required": false
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "browser",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "browser",
    "automation",
    "playwright",
    "screenshot",
    "capture"
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "playwright"
    ]
  }
}
