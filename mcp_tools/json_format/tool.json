{
  "name": "json_format",
  "version": "1.0.0",
  "description": "Format a JSON object as a pretty-printed string",
  "params": {
    "text": {
      "type": "string",
      "description": "JSON string to format",
      "required": true
    },
    "indent": {
      "type": "number",
      "description": "Indentation level",
      "required": false,
      "default": 2
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "data",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "json",
    "format",
    "pretty",
    "serialize",
    "data"
  ],
  "requires_api_key": false
}
