[
  {
    "description": "Parse simple JSON object",
    "args": {
      "text": "{\"name\":\"alice\",\"age\":30}"
    },
    "expected_keywords": [
      "alice",
      "30"
    ]
  },
  {
    "description": "Parse JSON array",
    "args": {
      "text": "[1,2,3]"
    },
    "expected_keywords": [
      "1",
      "2",
      "3"
    ]
  },
  {
    "description": "Invalid JSON returns error",
    "args": {
      "text": "{bad json}"
    },
    "expect_error": true
  }
]