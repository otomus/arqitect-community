{
  "name": "vuln_scan",
  "version": "1.0.0",
  "description": "Scan a file or directory for common security vulnerabilities",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "security",
  "tags": [
    "vulnerability",
    "scan",
    "security",
    "audit",
    "code"
  ],
  "parameters": [
    {
      "name": "path",
      "type": "string",
      "description": "File or directory to scan",
      "required": true
    },
    {
      "name": "type",
      "type": "string",
      "description": "Scan type: secrets, code, dependencies",
      "required": false,
      "default": "secrets"
    }
  ],
  "requires_api_key": false
}