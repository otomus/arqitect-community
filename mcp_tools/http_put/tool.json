{
  "name": "http_put",
  "version": "1.0.0",
  "description": "Send an HTTP PUT request to a URL",
  "params": {
    "url": {
      "type": "string",
      "description": "URL to send the request to",
      "required": true
    },
    "body": {
      "type": "string",
      "description": "Request body (JSON string)",
      "required": true
    },
    "headers": {
      "type": "string",
      "description": "JSON string of headers",
      "required": false,
      "default": "{}"
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "arqitect-community"
  },
  "category": "web",
  "implementations": {
    "python": "tool.py",
    "typescript": "tool.ts"
  },
  "tags": [
    "http",
    "put",
    "request",
    "api",
    "update"
  ],
  "requires_api_key": false
}
