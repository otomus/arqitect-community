{
  "name": "image_resize",
  "version": "1.0.0",
  "description": "Resize an image to the specified width and height",
  "params": {
    "input_path": {
      "type": "string",
      "description": "Path to the source image file",
      "required": true
    },
    "output_path": {
      "type": "string",
      "description": "Path where the resized image will be saved",
      "required": true
    },
    "width": {
      "type": "number",
      "description": "Target width in pixels",
      "required": true
    },
    "height": {
      "type": "number",
      "description": "Target height in pixels",
      "required": true
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "arqitect-community"
  },
  "category": "media",
  "implementations": {
    "python": "tool.py",
    "rust": "tool.rs"
  },
  "tags": [
    "image",
    "resize",
    "scale",
    "dimensions",
    "pillow"
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "Pillow"
    ],
    "rust": ["serde", "serde_json", "image"]
  }
}
