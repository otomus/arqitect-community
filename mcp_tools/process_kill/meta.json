{
  "name": "process_kill",
  "version": "1.0.0",
  "description": "Kill a process by PID with a specified signal",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "docker",
  "tags": [
    "process",
    "kill",
    "signal",
    "system",
    "infrastructure"
  ],
  "parameters": [
    {
      "name": "pid",
      "type": "number",
      "description": "Process ID to send the signal to",
      "required": true
    },
    {
      "name": "signal",
      "type": "string",
      "description": "Signal name to send (e.g. 'TERM', 'KILL', 'HUP')",
      "required": false,
      "default": "TERM"
    }
  ],
  "requires_api_key": false
}
