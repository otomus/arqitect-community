{
  "name": "file_read",
  "version": "1.0.0",
  "description": "Read the contents of a file at the given path",
  "params": {
    "path": {
      "type": "string",
      "description": "Path to the file to read",
      "required": true
    },
    "offset": {
      "type": "number",
      "description": "Line number to start reading from (0-based)",
      "required": false,
      "default": 0
    },
    "limit": {
      "type": "number",
      "description": "Maximum number of lines to read (0 = all)",
      "required": false,
      "default": 0
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "arqitect-community"
  },
  "category": "filesystem",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "file",
    "read",
    "open",
    "content",
    "text"
  ],
  "requires_api_key": false
}
