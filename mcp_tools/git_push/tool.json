{
  "name": "git_push",
  "version": "1.0.0",
  "description": "Push commits to a remote repository",
  "params": {
    "token": {
      "type": "string",
      "description": "User's Git access token for authentication",
      "required": true
    },
    "remote": {
      "type": "string",
      "description": "Remote name (default: origin)",
      "required": false
    },
    "branch": {
      "type": "string",
      "description": "Branch to push (default: current branch)",
      "required": false
    },
    "path": {
      "type": "string",
      "description": "Path to the Git repository (default: current directory)",
      "required": false
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "git",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "git",
    "version-control",
    "remote"
  ],
  "requires_api_key": true,
  "dependencies": {
    "python": [
      "gitpython"
    ]
  }
}
