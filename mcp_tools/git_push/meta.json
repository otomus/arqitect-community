{
  "name": "git_push",
  "version": "1.0.0",
  "description": "Push commits to a remote repository",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "git",
  "tags": [
    "git",
    "version-control",
    "remote"
  ],
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "description": "User's Git access token for authentication",
      "required": true
    },
    {
      "name": "remote",
      "type": "string",
      "description": "Remote name (default: origin)",
      "required": false
    },
    {
      "name": "branch",
      "type": "string",
      "description": "Branch to push (default: current branch)",
      "required": false
    },
    {
      "name": "path",
      "type": "string",
      "description": "Path to the Git repository (default: current directory)",
      "required": false
    }
  ],
  "requires_api_key": true,
  "dependencies": {
    "python": [
      "gitpython"
    ]
  }
}
