{
  "name": "news_fetch",
  "version": "1.0.0",
  "description": "Fetch news articles matching a search query",
  "params": {
    "query": {
      "type": "string",
      "description": "Search query for news articles",
      "required": true
    },
    "api_key": {
      "type": "string",
      "description": "API key for NewsAPI",
      "required": true
    },
    "count": {
      "type": "int",
      "description": "Number of articles to return (default 5)",
      "required": false
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "external",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "news",
    "articles",
    "search",
    "media"
  ],
  "requires_api_key": true,
  "dependencies": {
    "python": [
      "requests"
    ]
  }
}
