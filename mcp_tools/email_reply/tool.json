{
  "name": "email_reply",
  "version": "1.0.0",
  "description": "Reply to an email message",
  "params": {
    "id": {
      "type": "string",
      "description": "Message ID to reply to",
      "required": true
    },
    "body": {
      "type": "string",
      "description": "Reply body text",
      "required": true
    },
    "smtp_host": {
      "type": "string",
      "description": "SMTP server hostname",
      "required": true
    },
    "smtp_user": {
      "type": "string",
      "description": "SMTP authentication username",
      "required": true
    },
    "smtp_pass": {
      "type": "string",
      "description": "SMTP authentication password",
      "required": true
    },
    "imap_host": {
      "type": "string",
      "description": "IMAP server hostname",
      "required": true
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "communication",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "email",
    "reply",
    "respond",
    "imap",
    "smtp"
  ],
  "requires_api_key": true
}
