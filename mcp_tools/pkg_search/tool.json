{
  "name": "pkg_search",
  "version": "1.0.0",
  "description": "Search for available package versions",
  "params": {
    "query": {
      "type": "string",
      "description": "Package name to search for",
      "required": true
    },
    "manager": {
      "type": "string",
      "description": "Package manager to use (pip, npm, etc.)",
      "required": false,
      "default": "pip"
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30
}
