[
  {
    "description": "Query nested object",
    "args": {
      "text": "{\"user\":{\"name\":\"alice\"}}",
      "query": "user.name"
    },
    "expected_keywords": [
      "alice"
    ]
  },
  {
    "description": "Query array index",
    "args": {
      "text": "{\"items\":[{\"id\":1},{\"id\":2}]}",
      "query": "items.1.id"
    },
    "expected_keywords": [
      "2"
    ]
  },
  {
    "description": "Invalid path returns error",
    "args": {
      "text": "{\"a\":1}",
      "query": "b"
    },
    "expect_error": true
  }
]