{
  "name": "json_query",
  "version": "1.0.0",
  "description": "Query a JSON object using dot-notation path and return the matched value",
  "params": {
    "text": {
      "type": "string",
      "description": "JSON string to query",
      "required": true
    },
    "query": {
      "type": "string",
      "description": "Dot-notation path (e.g. \"user.name\" or \"items.0.id\")",
      "required": true
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "data",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "json",
    "query",
    "jmespath",
    "extract",
    "data"
  ],
  "requires_api_key": false
}
