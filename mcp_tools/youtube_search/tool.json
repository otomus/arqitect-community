{
  "name": "youtube_search",
  "version": "1.0.0",
  "description": "Search YouTube videos by query",
  "params": {
    "query": {
      "type": "string",
      "description": "Search query for YouTube videos",
      "required": true
    },
    "api_key": {
      "type": "string",
      "description": "API key for the YouTube Data API v3",
      "required": true
    },
    "max_results": {
      "type": "int",
      "description": "Maximum number of results to return (default 5)",
      "required": false
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "social",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "youtube",
    "search",
    "video",
    "media"
  ],
  "requires_api_key": true,
  "dependencies": {
    "python": [
      "requests"
    ]
  }
}
