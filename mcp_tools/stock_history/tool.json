{
  "name": "stock_history",
  "version": "1.0.0",
  "description": "Get historical stock price data for a given ticker symbol",
  "params": {
    "symbol": {
      "type": "string",
      "description": "Stock ticker symbol (e.g. AAPL, MSFT)",
      "required": true
    },
    "period": {
      "type": "string",
      "description": "Time period: 1d, 5d, 1mo, 3mo, or 1y",
      "required": true
    }
  },
  "runtime": "python",
  "entry": "tool.py",
  "timeout": 30,
  "author": {
    "github": "sentient-community"
  },
  "category": "external",
  "implementations": {
    "python": "tool.py"
  },
  "tags": [
    "stock",
    "history",
    "finance",
    "market",
    "chart"
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "yfinance"
    ]
  }
}
