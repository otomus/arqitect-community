{
  "name": "dir_list",
  "version": "1.0.0",
  "description": "List contents of a directory",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "filesystem",
  "tags": [
    "directory",
    "list",
    "ls",
    "files",
    "folders"
  ],
  "parameters": [
    {
      "name": "path",
      "type": "string",
      "description": "Directory path",
      "required": true
    },
    {
      "name": "pattern",
      "type": "string",
      "description": "Glob pattern to filter (e.g. \"*.py\")",
      "required": false,
      "default": "*"
    }
  ],
  "requires_api_key": false
}