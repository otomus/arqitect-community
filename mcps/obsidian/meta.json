{
  "name": "obsidian",
  "version": "1.0.0",
  "description": "Obsidian knowledge graph notes — search, read, create, and manage markdown notes",
  "source": "npm",
  "package": "obsidian-mcp-server",
  "command": ["npx", "-y", "obsidian-mcp-server"],
  "auth_type": "none",
  "tools": ["search_notes", "read_note", "create_note", "update_note", "list_notes"],
  "capabilities": ["notes", "knowledge_graph", "markdown", "writing", "pkm"],
  "category": "productivity"
}
